# Environment Configuration
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
BASE_URL=http://localhost:5000
LOG_LEVEL=info

# --- Postgres ---
DATABASE_URL=postgres://postgres:password@postgres:5432/riderpro?sslmode=disable
BACKUP_DATABASE_URL=postgres://postgres:password@postgres_backup:5432/riderpro_backup?sslmode=disable

# --- API Keys & Secrets ---
PIA_API_KEY=your-pia-api-key
SESSION_SECRET=your-session-secret-key-at-least-32-chars
POPS_JWT_SECRET=your-pops-jwt-secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=10

# --- Security & CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:5000,http://127.0.0.1:5173,http://127.0.0.1:5000,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000,http://127.0.0.1:5173,http://127.0.0.1:5000
ENABLE_CORS=true
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
SESSION_TIMEOUT=24
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=15
AUDIT_LOG_RETENTION=90

# --- External APIs ---
PRINTO_API_BASE_URL=https://pia.printo.in/api/v1

# --- Routing Provider (road-aware distances, travel time & ETA) ---
# Selects which engine optimize_path uses to compute real road distances.
# Switch providers by changing ROUTING_PROVIDER only — no code changes needed.
# Every provider falls back to straight-line (Haversine) automatically if its
# service is unreachable, so the app always works even if this is unset.
#
#   ors       → OpenRouteService cloud API (RECOMMENDED DEFAULT).
#               Free: 2,000 requests/day. No local data/server needed.
#               Register free at https://openrouteservice.org → paste key below.
#   google    → Google Distance Matrix API. Pay-per-use after $200/mo credit.
#               Needs GOOGLE_MAPS_API_KEY below.
#   haversine → Straight-line fallback. No external service. Dev/offline only
#               (inaccurate on real roads — typically 20-40% short).
#   osrm      → Self-hosted OSRM. Needs OSRM_BASE_URL + pre-processed map data.
#               Only for high-volume/offline self-hosting. Not the default.
ROUTING_PROVIDER=ors

# OpenRouteService API key — get a free one at https://openrouteservice.org
# Until this is set, optimize_path silently falls back to Haversine distances.
ORS_API_KEY=your-openrouteservice-api-key

# ORS endpoint (only change if self-hosting ORS; default is their public API).
ORS_BASE_URL=https://api.openrouteservice.org

# Google Maps API key — only required when ROUTING_PROVIDER=google.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Assumed average driving speed (km/h) used to estimate travel time when the
# Haversine fallback is active (no real durations available from a provider).
ROUTING_AVERAGE_SPEED_KMH=30

# OSRM base URL — only used when ROUTING_PROVIDER=osrm (self-hosted setups).
# OSRM_BASE_URL=http://osrm:5000

# --- Database (SQLite Local - Deprecated but kept for reference) ---
DATABASE_PATH=./data/riderpro.db
DB_BACKUP_ENABLED=false
DB_BACKUP_INTERVAL=24
DB_MAX_BACKUPS=7
DB_VACUUM_INTERVAL=168
DB_WAL_MODE=true
DB_JOURNAL_MODE=WAL
DB_SYNCHRONOUS=NORMAL
DB_CACHE_SIZE=10000
DB_TEMP_STORE=MEMORY
FEATURE_DB_OPTIMIZATION=false

# --- Features & Route Tracking ---
ROUTE_TRACKING_ENABLED=true
ROUTE_TRACKING_INTERVAL=30
MAX_COORDINATES_PER_SESSION=10000
DATA_RETENTION_DAYS=90
DEFAULT_FUEL_EFFICIENCY=15.0
DEFAULT_FUEL_PRICE=1.5
BATTERY_OPTIMIZATION=true
OFFLINE_SYNC=true
REAL_TIME_UPDATES=true
ANALYTICS_ENABLED=true
EXPORT_ENABLED=true
AUDIT_LOGGING=true
PRIVACY_MODE=false

# --- Feature Flags ---
FEATURE_ROUTE_TRACKING=true
FEATURE_LIVE_TRACKING=true
FEATURE_ROUTE_ANALYTICS=true
FEATURE_ROUTE_VISUALIZATION=true
FEATURE_ROUTE_OPTIMIZATION=true
FEATURE_MOBILE_OPTIMIZATION=true
FEATURE_ADVANCED_ANALYTICS=false
FEATURE_DATA_EXPORT=true
FEATURE_AUDIT_LOGS=false
FEATURE_PRIVACY_CONTROLS=true
FEATURE_PERFORMANCE_MONITORING=false

# --- Monitoring & Alerts ---
MONITORING_ENABLED=false
HEALTH_CHECK_INTERVAL=60
PERFORMANCE_METRICS=false
ERROR_TRACKING=true
ALERTING_ENABLED=false
EMAIL_ALERTS_ENABLED=false
SMTP_PORT=587
SMTP_SECURE=false

WEBHOOK_ALERTS_ENABLED=false
SLACK_ALERTS_ENABLED=false
SLACK_CHANNEL=#alerts

# --- Thresholds ---
ERROR_RATE_THRESHOLD=5.0
RESPONSE_TIME_THRESHOLD=1000
MEMORY_USAGE_THRESHOLD=80.0
DISK_USAGE_THRESHOLD=85.0
DATABASE_SIZE_THRESHOLD=1000

# --- File Upload ---
MAX_FILE_SIZE=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif
UPLOAD_DIR=./uploads

# --- Debug ---
DEBUG=false
VERBOSE_LOGGING=false

# --- Rider OTP login (phone + WhatsApp OTP) ---
# 'console' logs the code to the Django log (local dev). Set 'botspace' in prod.
OTP_PROVIDER=console
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN=45
# Lenient abuse caps (anti SMS/WhatsApp pumping)
OTP_MAX_PER_PHONE_PER_DAY=10
OTP_MAX_PER_IP_PER_HOUR=30

# Botspace WhatsApp Business API (required when OTP_PROVIDER=botspace).
# Send endpoint: POST {BOTSPACE_API_BASE}/{BOTSPACE_CHANNEL_ID}/message/send-message?apiKey=...
BOTSPACE_API_BASE=https://public-api.bot.space/v1
BOTSPACE_API_KEY=
BOTSPACE_CHANNEL_ID=
BOTSPACE_OTP_TEMPLATE=
